# Required: Groq API key (https://console.groq.com)
GROQ_API_KEY=your-groq-api-key

# Optional: Model override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Ollama for local embeddings (defaults shown)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text

# Optional: Qdrant vector database (defaults to localhost:6333)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-qdrant-api-key

# Optional: Swiggy Dineout (for live restaurant booking)
# SWIGGY_TOKEN=your-swiggy-oauth-token
