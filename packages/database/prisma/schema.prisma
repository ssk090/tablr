generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id                String   @id @default(uuid())
  name              String
  bio               String   @default("")
  professionalTitle String?  @map("professional_title")
  company           String?
  email             String?  @unique
  linkedinUrl       String?  @map("linkedin_url")
  interests         Json     @default("[]")
  city              String   @default("Bangalore")
  diningPreferences Json     @default("{}") @map("dining_preferences")
  semanticProfile   Json?    @map("semantic_profile")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  intents       DinnerIntent[]
  eventsCreated DiningEvent[]    @relation("CreatedBy")
  memberships   EventMember[]
  feedback      Feedback[]
  notifications Notification[]
  messages      Message[]
  chats         Chat[]
  embedding     Embedding?

  @@map("profiles")
}

model Chat {
  id        String    @id @default(uuid())
  profileId String    @map("profile_id")
  title     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  profile  Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("chats")
}

model Message {
  id        String   @id @default(uuid())
  chatId    String?  @map("chat_id")
  profileId String?  @map("profile_id")
  parentId  String?  @map("parent_id")
  role      String   // "user", "assistant", "system"
  content   String
  metadata  Json?
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  chat    Chat?    @relation(fields: [chatId], references: [id], onDelete: Cascade)
  profile Profile? @relation(fields: [profileId], references: [id], onDelete: Cascade)
  parent  Message? @relation("MessageHistory", fields: [parentId], references: [id])
  replies Message[] @relation("MessageHistory")

  @@map("messages")
}

model Embedding {
  profileId String   @id @map("profile_id")
  vector    Json     // Storing as JSON for compatibility, can be optimized to pgvector later
  model     String
  createdAt DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("embeddings")
}

model Restaurant {
  id           String  @id
  name         String
  cuisine      Json    @default("[]")
  area         String
  address      String
  rating       Float   @default(0)
  costForTwo   Float   @default(0) @map("cost_for_two")
  groupFriendly Boolean @default(false) @map("group_friendly")
  maxGroupSize Int     @default(6) @map("max_group_size")
  ambiance     Json    @default("[]")
  highlights   Json    @default("[]")
  lat          Float?
  lng          Float?

  events DiningEvent[]

  @@map("restaurants")
}

model DiningEvent {
  id             String      @id @default(uuid())
  restaurantId   String      @map("restaurant_id")
  restaurantName String      @map("restaurant_name")
  status         EventStatus @default(FORMING)
  scheduledDate  String?     @map("scheduled_date")
  scheduledTime  String?     @map("scheduled_time")
  guestCount     Int         @default(4) @map("guest_count")
  createdBy      String      @map("created_by")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  // Relations
  restaurant Restaurant     @relation(fields: [restaurantId], references: [id])
  creator    Profile        @relation("CreatedBy", fields: [createdBy], references: [id])
  members    EventMember[]
  feedback   Feedback[]
  intents    DinnerIntent[]

  @@map("dining_events")
}

enum EventStatus {
  FORMING   @map("forming")
  CONFIRMED @map("confirmed")
  COMPLETED @map("completed")
  CANCELLED @map("cancelled")
}

model EventMember {
  eventId   String       @map("event_id")
  profileId String       @map("profile_id")
  status    MemberStatus @default(INVITED)
  joinedAt  DateTime     @default(now()) @map("joined_at")

  event   DiningEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  profile Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@id([eventId, profileId])
  @@map("event_members")
}

enum MemberStatus {
  INVITED  @map("invited")
  JOINED   @map("joined")
  DECLINED @map("declined")
}

model Feedback {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  profileId String   @map("profile_id")
  rating    Int
  comment   String   @default("")
  createdAt DateTime @default(now()) @map("created_at")

  event   DiningEvent @relation(fields: [eventId], references: [id])
  profile Profile     @relation(fields: [profileId], references: [id])

  @@map("feedback")
}

model DinnerIntent {
  id             String       @id @default(uuid())
  profileId      String       @map("profile_id")
  date           String
  timeSlot       TimeSlot     @default(DINNER) @map("time_slot")
  preferredArea  String?      @map("preferred_area")
  groupSize      Int          @default(4) @map("group_size")
  status         IntentStatus @default(OPEN)
  matchedEventId String?      @map("matched_event_id")
  createdAt      DateTime     @default(now()) @map("created_at")

  profile      Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  matchedEvent DiningEvent? @relation(fields: [matchedEventId], references: [id])

  @@map("dinner_intents")
}

enum TimeSlot {
  LUNCH  @map("lunch")
  DINNER @map("dinner")
}

enum IntentStatus {
  OPEN      @map("open")
  MATCHED   @map("matched")
  EXPIRED   @map("expired")
  CANCELLED @map("cancelled")
}

model Notification {
  id        String             @id @default(uuid())
  profileId String             @map("profile_id")
  type      NotificationType
  targetId  String             @map("target_id")
  status    NotificationStatus @default(PENDING)
  sentAt    DateTime?          @map("sent_at")
  createdAt DateTime           @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  MATCH_FOUND    @map("match_found")
  EVENT_INVITE   @map("event_invite")
  EVENT_REMINDER @map("event_reminder")
}

enum NotificationStatus {
  PENDING @map("pending")
  SENT    @map("sent")
  FAILED  @map("failed")
}
